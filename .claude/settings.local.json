{
  "permissions": {
    "allow": [
      "Bash(node scripts/check-governance.mjs)",
      "mcp__MiniMax__web_search",
      "WebSearch",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(bash scripts/session-start.sh)",
      "Bash(npm run:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rev-parse:*)",
      "Bash(chmod:*)",
      "Bash(node scripts/check-governance.mjs --no-docs-gate)",
      "Bash(node scripts/check-governance.mjs --help)",
      "Bash(bash scripts/req-check.sh)",
      "Bash(echo \"Exit code: $?\")",
      "Bash(npm test:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/session-start.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/req-check.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
