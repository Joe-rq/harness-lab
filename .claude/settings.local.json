      "mcp__MiniMax__web_search",
      "WebSearch",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(bash scripts/session-start.sh)",
      "Bash(npm run:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rev-parse:*)",
      "Bash(chmod:*)",
      "Bash(node scripts/check-governance.mjs --no-docs-gate)",
      "Bash(node scripts/check-governance.mjs --help)",
      "Bash(bash scripts/req-check.sh)",
      "Bash(echo \"Exit code: $?\")",
      "Bash(npm test:*)",
      "Bash(rm:*)",
      "Bash(cd:*)",
      "Bash(grep:*)",
      "Bash(node:*)",
      "Bash(rm -f \"scripts・ && cp D:03resource_Projectsharness-labscriptsreq-check.sh D:03resource_Projectsagent-flow-litescripts・\")",
      "Bash(rm -f .claude/.docs-impact-status .claude/.req-complete-status)",
      "Bash(\"D:\\\\03resource\\\\_Projects\\\\agent-flow-lite\\\\requirements\\\\test.txt\")",
      "Bash(bash -n \"D:\\\\03resource\\\\_Projects\\\\harness-lab\\\\scripts\\\\req-check.sh\")",
      "Bash(bash -x scripts/req-check.sh)",
      "Bash(mv docs/plans/harness-lab-auto-research-optimization.md context/experience/2026-03-28-autoresearch-optimization-design.md)",
      "Bash(mv docs/plans/harness-lab-scope-results-optimization.md context/experience/2026-03-28-scope-results-optimization-design.md)",
      "Bash(mv docs/plans/product-opportunity-research-2026-03-23.md context/experience/2026-03-23-product-opportunity-research.md)",
      "Bash(echo \"Exit: $?\")"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/session-start.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/req-check.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
