{
  "rules": [
    {
      "id": "package-json-scripts",
      "description": "Package script changes must update maintainer-facing docs.",
      "triggers": ["package.json"],
      "requireAny": ["README.md", "CONTRIBUTING.md"]
    },
    {
      "id": "governance-scripts",
      "description": "Governance script changes must update maintainer-facing docs.",
      "triggers": ["scripts/check-governance.mjs", "scripts/docs-verify.mjs"],
      "requireAny": ["README.md", "CONTRIBUTING.md"]
    },
    {
      "id": "req-cli-workflow",
      "description": "REQ CLI workflow changes must sync the main entry docs.",
      "triggers": ["scripts/req-cli.mjs"],
      "requireAny": ["README.md", "AGENTS.md", "CLAUDE.md", "CONTRIBUTING.md"]
    },
    {
      "id": "agents-entry",
      "description": "AGENTS.md changes must update CLAUDE.md or README.md.",
      "triggers": ["AGENTS.md"],
      "requireAny": ["CLAUDE.md", "README.md"]
    },
    {
      "id": "claude-entry",
      "description": "CLAUDE.md changes must update AGENTS.md or README.md.",
      "triggers": ["CLAUDE.md"],
      "requireAny": ["AGENTS.md", "README.md"]
    },
    {
      "id": "req-template",
      "description": "REQ template changes must sync entry or contribution docs.",
      "triggers": ["requirements/REQ_TEMPLATE.md"],
      "requireAny": ["README.md", "AGENTS.md", "CONTRIBUTING.md"]
    },
    {
      "id": "req-index",
      "description": "REQ index changes that affect workflow expectations must sync entry docs.",
      "triggers": ["requirements/INDEX.md"],
      "requireAny": ["README.md", "AGENTS.md", "CLAUDE.md", "CONTRIBUTING.md"]
    },
    {
      "id": "skills-content",
      "description": "Skill content changes must sync the skills navigation docs.",
      "triggers": ["skills/plan/", "skills/review/", "skills/qa/", "skills/ship/"],
      "requireAny": ["skills/README.md", "README.md", "CONTRIBUTING.md"]
    }
  ]
}
